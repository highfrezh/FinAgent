# =============================================
# FinAgent — Environment Configuration
# =============================================

# App
APP_NAME=FinAgent
APP_ENV=development
DEBUG=true
SECRET_KEY=finagent-secret-key-change-in-production

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://finagent:finagent123@localhost:5432/finagent_db
DATABASE_SYNC_URL=postgresql://finagent:finagent123@localhost:5432/finagent_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
LLM_PROVIDER=ollama

# Ollama (local - free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Anthropic Claude (for demo day only)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Auth
JWT_SECRET_KEY=finagent-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30